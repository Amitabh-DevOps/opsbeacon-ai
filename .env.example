# OpsBeacon AI Local Environment Variables Configuration Example
# Copy this file to '.env' and fill in your values.

# AWS Region to use for Bedrock and SES
AWS_REGION=us-east-1

# Amazon Bedrock Model ID (e.g., Nova Lite or Claude 3 Haiku)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Verified Amazon SES Sender Email Address
SENDER_EMAIL=devops-alerts@yourdomain.com

# Verified Amazon SES Recipient Email Address
RECIPIENT_EMAIL=you@yourdomain.com

# Max RSS items to fetch per feed per run (default: 5)
RSS_LIMIT=5

# Optional: AWS Profile if running locally with a specific profile
# AWS_PROFILE=default
